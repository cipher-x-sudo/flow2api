FROM python:3.11-slim

WORKDIR /app

COPY requirements-agent-gateway.txt .
RUN pip install --no-cache-dir --root-user-action=ignore -r requirements-agent-gateway.txt

COPY src/agent_gateway/ /app/src/agent_gateway/

ENV PYTHONUNBUFFERED=1
ENV PYTHONPATH=/app

EXPOSE 9080

CMD ["uvicorn", "src.agent_gateway.main:app", "--host", "0.0.0.0", "--port", "9080"]
